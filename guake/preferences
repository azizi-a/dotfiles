[general]
compat-delete='delete-sequence'
display-n=-1
display-tab-names=1
gtk-prefer-dark-theme=true
gtk-theme-name='Yaru-prussiangreen-dark'
gtk-use-system-default-theme=true
hide-tabs-if-one-tab=true
history-size=2000
load-guake-yml=true
max-tab-name-length=100
mouse-display=false
open-tab-cwd=true
prompt-on-quit=true
quick-open-command-line='gedit %(file_path)s'
restore-tabs-notify=true
restore-tabs-startup=true
save-tabs-when-changed=true
scroll-keystroke=true
search-engine=1
set-window-title=false
start-at-login=true
tab-ontop=true
use-default-font=false
use-popup=true
use-scrollbar=false
use-trayicon=true
