[core]
	editor = cursor --wait
	autocrlf = input
	ignoreCase = false
  pager = delta
[user]
	name = Azizi
	email = 64193693+azizi-a@users.noreply.github.com
	signingkey = ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIC3Jvt3xlTJL2aQXTk9kKSFdX+a1AaGcNBetTd2xi87E
[init]
	defaultBranch = main
[interactive]
  diffFilter = delta --color-only
[delta]
  navigate = true    # use n and N to move between diff sections
  light = false      # set to true if you're in a terminal w/ a light background color (e.g. the default macOS terminal)
  line-numbers = true
  side-by-side = true
[merge]
  conflictstyle = diff3
[diff]
  colorMoved = default
[commit]
	gpgsign = true
[gpg]
	format = ssh
[tag]
	gpgsign = true
[gpg "ssh"]
	program = /Applications/1Password.app/Contents/MacOS/op-ssh-sign
